{
   "action": {
      "default_icon": "images/128.png",
      "default_popup": "popup.html",
      "default_title": "点击下载弹幕"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "js": [ "FileSave.js", "jszip.min.js", "protobuf.min.js", "Sortable.min.js", "content.js", "combine.js" ],
      "matches": [ "https://www.bilibili.com/*" ]
   } ],
   "description": "下载bilibili/B站的弹幕,生成供本地播放器使用的ass字幕文件",
   "icons": {
      "128": "images/128.png",
      "16": "images/16.png",
      "48": "images/48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "B站bilibil弹幕下载生成ASS字幕",
   "permissions": [ "activeTab", "storage", "scripting" ],
   "short_name": "B站弹幕下载",
   "update_url": "https://edge.microsoft.com/extensionwebstorebase/v1/crx",
   "version": "1.3.3",
   "web_accessible_resources": [ {
      "matches": [ "https://www.bilibili.com/*" ],
      "resources": [ "progress.html", "logging.html", "combine.html" ]
   } ]
}
