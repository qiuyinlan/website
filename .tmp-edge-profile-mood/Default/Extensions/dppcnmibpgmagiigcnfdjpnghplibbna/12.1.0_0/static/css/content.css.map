  box-shadow: 0 2px 6px rgba(64, 169, 255, 0.2) !important

  &:hover
    background: linear-gradient(135deg, rgba(64, 169, 255, 0.2) 0%, rgba(24, 144, 255, 0.2) 100%) !important
    border-color: rgba(64, 169, 255, 0.4) !important
    transform: translateY(-1px) !important
    box-shadow: 0 4px 12px rgba(64, 169, 255, 0.3) !important

  .anticon
    font-size: 12px !important

.bookmark-locate-delete-btn
  background: linear-gradient(135deg, rgba(239, 68, 68, 0.1) 0%, rgba(220, 38, 38, 0.1) 100%) !important
  border: 1px solid rgba(239, 68, 68, 0.2) !important
  color: #ef4444 !important
  width: 28px !important
  height: 28px !important
  border-radius: 50% !important
  display: flex !important
  align-items: center !important
  justify-content: center !important
  transition: all 0.3s ease !important
  box-shadow: 0 2px 6px rgba(239, 68, 68, 0.2) !important

  &:hover
    background: linear-gradient(135deg, rgba(239, 68, 68, 0.2) 0%, rgba(220, 38, 38, 0.2) 100%) !important
    border-color: rgba(239, 68, 68, 0.4) !important
    transform: translateY(-1px) !important
    box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3) !important

  .anticon
    font-size: 12px !important

.bookmark-locate-more-btn
  background: linear-gradient(135deg, rgba(107, 114, 128, 0.1) 0%, rgba(75, 85, 99, 0.1) 100%) !important
  border: 1px solid rgba(107, 114, 128, 0.2) !important
  color: #6b7280 !important
  width: 28px !important
  height: 28px !important
  border-radius: 50% !important
  display: flex !important
  align-items: center !important
  justify-content: center !important
  transition: all 0.3s ease !important
  box-shadow: 0 2px 6px rgba(107, 114, 128, 0.2) !important

  &:hover
    background: linear-gradient(135deg, rgba(107, 114, 128, 0.2) 0%, rgba(75, 85, 99, 0.2) 100%) !important
    border-color: rgba(107, 114, 128, 0.4) !important
    transform: translateY(-1px) !important
    box-shadow: 0 4px 12px rgba(107, 114, 128, 0.3) !important

  .anticon
    font-size: 12px !important

// 添加书签弹出框美化样式
.bookmark-upsert-modal
  .ant-modal-content
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 250, 252, 0.98) 100%)
    border: 1px solid rgba(64, 169, 255, 0.2)
    border-radius: 20px
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.15)
    backdrop-filter: blur(20px)

  .ant-modal-header
    background: linear-gradient(135deg, rgba(64, 169, 255, 0.1) 0%, rgba(24, 144, 255, 0.1) 100%)
    border-bottom: 1px solid rgba(64, 169, 255, 0.2)
    border-radius: 20px 20px 0 0
    padding: 20px 24px

  .ant-modal-body
    background: transparent
    padding: 24px

  .ant-modal-footer
    background: transparent
    border-top: 1px solid rgba(64, 169, 255, 0.1)
    border-radius: 0 0 20px 20px
    padding: 16px 24px

// 书签弹出框标题样式
.bookmark-upsert-title
  display: flex
  align-items: center
  gap: 12px
  margin: 0

  .title-icon
    width: 40px
    height: 40px
    background: linear-gradient(135deg, #FB9000 0%, #ff9500 100%)
    border-radius: 10px
    display: flex
    align-items: center
    justify-content: center
    color: white
    font-size: 18px
    box-shadow: 0 4px 12px rgba(251, 144, 0, 0.3)

  .title-text
    font-size: 18px
    font-weight: 600
    background: linear-gradient(135deg, #FB9000 0%, #ff9500 100%)
    -webkit-background-clip: text
    -webkit-text-fill-color: transparent
    background-clip: text
    margin-right: 12px

// 书签输入框样式
.bookmark-input-group
  margin-bottom: 20px

  label
    display: block
    font-weight: 600
    color: #1f2937
    margin-bottom: 8px
    font-size: 14px

  .ant-input
    background: rgba(255, 255, 255, 0.9)
    border: 2px solid rgba(64, 169, 255, 0.15)
    border-radius: 12px
    padding: 12px 16px
    font-size: 14px
    transition: all 0.3s ease
    backdrop-filter: blur(10px)
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05)

    &:focus
      border-color: #40a9ff
      box-shadow: 0 0 0 3px rgba(64, 169, 255, 0.1)
      background: rgba(255, 255, 255, 0.95)

    &::placeholder
      color: rgba(107, 114, 128, 0.7)

// 书签标签输入区域样式
.bookmark-tags-section
  margin-top: 20px

  label
    display: block
    font-weight: 600
    color: #1f2937
    margin-bottom: 12px
    font-size: 14px

  .tag-input
    background: rgba(255, 255, 255, 0.9)
    border: 2px solid rgba(64, 169, 255, 0.15)
    border-radius: 12px
    padding: 12px 16px
    font-size: 14px
    transition: all 0.3s ease
    backdrop-filter: blur(10px)
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05)
    width: 200px

    &:focus
      border-color: #40a9ff
      box-shadow: 0 0 0 3px rgba(64, 169, 255, 0.1)
      background: rgba(255, 255, 255, 0.95)

    &::placeholder
      color: rgba(107, 114, 128, 0.7)

// 书签弹出框按钮样式
.bookmark-modal-buttons
  display: flex
  gap: 16px
  justify-content: flex-end
  padding: 8px 0

// 取消按钮样式
.bookmark-cancel-btn
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(248, 250, 252, 0.95) 100%)
  border: 2px solid rgba(107, 114, 128, 0.2)
  border-radius: 12px
  color: #374151
  font-weight: 600
  font-size: 14px
  padding: 12px 24px
  min-width: 100px
  height: 44px
  line-height: 1
  display: flex
  align-items: center
  justify-content: center
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1)
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05)
  backdrop-filter: blur(10px)

  &:hover
    background: linear-gradient(135deg, rgba(239, 246, 255, 0.95) 0%, rgba(219, 234, 254, 0.95) 100%)
    border-color: rgba(64, 169, 255, 0.4)
    color: #1e40af
    transform: translateY(-2px)
    box-shadow: 0 8px 20px rgba(64, 169, 255, 0.15)

  &:active
    transform: translateY(-1px)
    box-shadow: 0 4px 12px rgba(64, 169, 255, 0.2)

// 确认按钮样式
.bookmark-confirm-btn
  background: linear-gradient(135deg, #40a9ff 0%, #1890ff 100%)
  border: none
  border-radius: 12px
  color: white
  font-weight: 600
  font-size: 14px
  padding: 12px 24px
  min-width: 100px
  height: 44px
  line-height: 1
  display: flex
  align-items: center
  justify-content: center
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1)
  box-shadow: 0 4px 15px rgba(64, 169, 255, 0.3)
  position: relative
  overflow: hidden

  &::before
    content: ''
    position: absolute
    top: 0
    left: -100%
    width: 100%
    height: 100%
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent)
    transition: left 0.5s

  &:hover
    background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%)
    transform: translateY(-3px)
    box-shadow: 0 12px 25px rgba(64, 169, 255, 0.4)

    &::before
      left: 100%

  &:active
    transform: translateY(-1px)
    box-shadow: 0 6px 18px rgba(64, 169, 255, 0.35)

  &:focus
    outline: none
    box-shadow: 0 0 0 3px rgba(64, 169, 255, 0.2), 0 4px 15px rgba(64, 169, 255, 0.3)

  .edit-btn
    background: rgba(64, 169, 255, 0.1)
    border: 1px solid rgba(64, 169, 255, 0.2)
    color: #40a9ff
    transition: all 0.3s ease

    &:hover
      background: rgba(64, 169, 255, 0.2)
      border-color: #40a9ff
      transform: scale(1.1)

  .export-btn
    background: linear-gradient(135deg, #40a9ff 0%, #1890ff 100%)
    border: none
    color: white
    transition: all 0.3s ease
    box-shadow: 0 2px 8px rgba(64, 169, 255, 0.3)

    &:hover
      transform: scale(1.1)
      box-shadow: 0 4px 12px rgba(64, 169, 255, 0.4)

  .xmind-btn
    background: linear-gradient(135deg, #FA4339 0%, #ff6b6b 100%)
    border: none
    color: white
    transition: all 0.3s ease
    box-shadow: 0 2px 8px rgba(250, 67, 57, 0.3)

    &:hover
      transform: scale(1.1)
      box-shadow: 0 4px 12px rgba(250, 67, 57, 0.4)
