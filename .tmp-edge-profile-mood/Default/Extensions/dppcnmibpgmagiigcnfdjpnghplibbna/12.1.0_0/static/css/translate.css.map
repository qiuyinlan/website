.content-container {
  display: inline-block;
  background-color #f5f5f5
  padding 4px
}

.trans-eng {
  width 22px
  margin 4px
  cursor pointer
}

.trans-eng:hover {
  outline 1px solid rgba(0, 21, 41, 0.6)
}

.anno-action {
  display: inline-block;
  width: 22px;
  height: 22px;
  cursor: pointer;
  margin 4px 4px
  border: 1px solid transparent;
}

.anno-action:hover {
  border: 1px solid rgba(0, 21, 41, 0.6);
}


.highlight-red {
  background-color: #ff595e !important;
  color: white !important;
}

.highlight-brown {
  background-color: #78290f !important;
  color: white !important;
}

.highlight-yellow {
  background-color: #ffca3a !important;
  color: white !important;
}

.highlight-green {
  background-color: #8ac926 !important;
  color: white !important;
}


.highlight-blue {
  background-color: #1982c4 !important;
  color: white !important;
}

.highlight-purple {
  background-color: #6a4c93 !important;
  color: white !important;
}
