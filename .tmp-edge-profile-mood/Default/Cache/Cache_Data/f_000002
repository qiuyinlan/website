/* --- History Dialog --- */
.history-dialog {
  width: min(900px, calc(100vw - 32px));
  border: 0;
  padding: 0;
  background: transparent;
}

.history-dialog::backdrop {
  background: rgba(20, 16, 12, 0.42);
  backdrop-filter: blur(6px);
}

.history-shell {
  display: grid;
  gap: 16px;
  max-height: min(88vh, 900px);
  overflow-y: auto;
  background: var(--bg);
  border-radius: 32px;
  border: 1px solid rgba(255, 255, 255, 0.7);
  padding: 24px;
  box-shadow: var(--shadow);
}

.history-tabs {
  display: flex;
  gap: 4px;
  background: rgba(31, 27, 22, 0.06);
  border-radius: var(--radius-sm);
  padding: 4px;
}

.history-tab {
  min-height: 38px;
  padding: 0 20px;
  border-radius: calc(var(--radius-sm) - 2px);
  border: 0;
  background: transparent;
  color: var(--muted);
  font-weight: 600;
  font-size: 0.95rem;
  transition: background 120ms ease, color 120ms ease;
}

.history-tab.is-active {
  background: white;
  color: var(--ink);
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.history-tab:hover:not(.is-active) {
  color: var(--ink);
}

/* --- History Navigation --- */
.history-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 12px 0;
  user-select: none;
}

.history-nav-btn {
  min-height: 38px;
  min-width: 38px;
  border-radius: 10px;
  border: 1px solid var(--line);
  background: white;
  color: var(--ink);
  font-size: 1.1rem;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 120ms ease, transform 120ms ease;
}

.history-nav-btn:hover {
  background: var(--accent-soft);
  transform: translateY(-1px);
}

.history-nav-btn:disabled {
