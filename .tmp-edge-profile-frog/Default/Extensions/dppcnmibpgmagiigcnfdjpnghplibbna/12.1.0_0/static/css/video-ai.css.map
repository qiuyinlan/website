// 设计升级：多色点缀 + 紧凑进度区
$bg-page = linear-gradient(165deg, #060a1a 0%, #0d1229 35%, #151b3d 100%)
$bg-glass = linear-gradient(175deg, rgba(255, 255, 255, 0.07) 0%, rgba(255, 255, 255, 0.02) 100%)
$border-subtle = rgba(255, 255, 255, 0.12)
$border-card = rgba(255, 255, 255, 0.1)
$accent-blue = #5ba3ff
$accent-blue-light = #7ec4ff
$accent-blue-rgb = 91, 163, 255
$accent-cyan = #4dd0e1
$accent-cyan-rgb = 77, 208, 225
$accent-violet = #b388ff
$accent-violet-rgb = 179, 136, 255
$accent-emerald = #69f0ae
$accent-emerald-rgb = 105, 240, 174
$accent-glow = rgba(91, 163, 255, 0.35)
$text-primary = #e8eaef
$text-secondary = rgba(255, 255, 255, 0.55)
$ease-out = cubic-bezier(0.4, 0, 0.2, 1)
$radius-lg = 14px
$radius-md = 10px
$radius-sm = 8px
$shadow-soft = 0 4px 24px rgba(0, 0, 0, 0.2)
$shadow-card = 0 2px 12px rgba(0, 0, 0, 0.15), 0 0 0 1px rgba(255, 255, 255, 0.04) inset

.video-ai-page
  display flex
  flex-direction column
  height 100vh
  background $bg-page
  color $text-primary
  font-family -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif
  -webkit-font-smoothing antialiased
  -moz-osx-font-smoothing grayscale
  text-rendering optimizeLegibility
  transform translateZ(0)
  contain layout style paint
  isolation isolate
  position relative

  // 顶部微光：蓝 + 紫双色
  &::before
    content ''
    position absolute
    top 0
    left 0
    right 0
    height 200px
    background radial-gradient(ellipse 100% 60% at 30% -10%, rgba(91, 163, 255, 0.1) 0%, transparent 50%),
                radial-gradient(ellipse 80% 50% at 75% -5%, rgba(179, 136, 255, 0.06) 0%, transparent 50%)
    pointer-events none
    z-index 0

// ========== 录制进度展示区（紧凑高度）==========
.video-ai-recording-area
  flex-shrink 0
  min-height 88px
  display flex
  align-items center
  justify-content center
  gap 20px
  padding 14px 24px 16px
  box-sizing border-box
  background $bg-glass
  border-bottom 1px solid $border-subtle
  backdrop-filter blur(16px)
  -webkit-backdrop-filter blur(16px)
  box-shadow $shadow-soft, 0 1px 0 rgba(255, 255, 255, 0.06) inset
  position relative
  z-index 1

.video-ai-progress-wrap
  flex 1
  min-width 0
  display flex
  flex-direction column
  gap 8px

.video-ai-progress-label
  display flex
  align-items center
  justify-content space-between
  gap 10px

.video-ai-progress-text
  font-size 12px
  font-weight 600
  color $text-secondary
  letter-spacing 0.4px
  text-transform uppercase
  font-variant-numeric tabular-nums

.video-ai-progress-pct
  font-size 13px
  font-weight 700
  color $accent-cyan
  font-variant-numeric tabular-nums
  letter-spacing 0.05em
  text-shadow 0 0 20px rgba($accent-cyan-rgb, 0.4)

// 水平进度条：占满可用宽度（稍细）
.video-ai-progress-bar
  width 100%
  height 8px
  background rgba(0, 0, 0, 0.3)
  border-radius 4px
  overflow hidden
  border 1px solid rgba(255, 255, 255, 0.06)
  box-shadow 0 2px 6px rgba(0, 0, 0, 0.25) inset

.video-ai-progress-fill
  height 100%
  min-width 0
  background linear-gradient(90deg, $accent-blue 0%, $accent-cyan 60%, $accent-emerald 100%)
  border-radius 4px
  transition width 0.4s $ease-out
  box-shadow 0 0 16px rgba($accent-blue-rgb, 0.4), 0 0 24px rgba($accent-cyan-rgb, 0.2)
  position relative

.video-ai-transcript-error
  font-size 12px
  color #f87171
  margin-top 4px

.video-ai-upload-status
  font-size 12px
  color $text-secondary
  margin-top 4px

.video-ai-upload-done
  color $accent-emerald

.video-ai-opus-info
  display flex
  align-items center
  gap 16px
  margin-top 6px
  font-size 12px
  color $text-secondary
  font-variant-numeric tabular-nums

.video-ai-opus-play-btn,
.video-ai-opus-download-btn
  display inline-flex
  align-items center
  justify-content center
  width 32px
  height 32px
  padding 0
  border none
  border-radius 50%
  background rgba($accent-blue-rgb, 0.25)
  color rgba(255, 255, 255, 0.95)
  cursor pointer
  transition background 0.2s, transform 0.15s
  flex-shrink 0

  &:hover
    background rgba($accent-blue-rgb, 0.4)

  &:active
    transform scale(0.95)

.video-ai-progress-fill
  &::after
    content ''
    position absolute
    top 0
    left 0
    right 0
    height 45%
    background linear-gradient(180deg, rgba(255, 255, 255, 0.3) 0%, transparent 100%)
    border-radius 4px 4px 0 0

.video-ai-start-btn
  flex-shrink 0
  padding 0 20px
  height 40px
  border-radius 20px
  border 1.5px solid rgba($accent-blue-rgb, 0.4)
  background linear-gradient(145deg, rgba($accent-blue-rgb, 0.22) 0%, rgba($accent-blue-rgb, 0.08) 100%)
  color rgba(255, 255, 255, 0.98)
  font-size 14px
  font-weight 600
  cursor pointer
  display flex
  align-items center
  justify-content center
  transition all 0.3s $ease-out
  outline none
  position relative
  overflow hidden
  box-shadow 0 4px 16px rgba(0, 0, 0, 0.2), 0 0 0 1px rgba(255, 255, 255, 0.05) inset

  &:hover
    background linear-gradient(145deg, rgba($accent-blue-rgb, 0.35) 0%, rgba($accent-blue-rgb, 0.18) 100%)
    border-color rgba($accent-blue-rgb, 0.65)

.video-ai-retry-btn
  flex-shrink 0
  width 40px
  height 40px
  border-radius 50%
  border 1.5px solid rgba($accent-blue-rgb, 0.4)
  background linear-gradient(145deg, rgba($accent-blue-rgb, 0.22) 0%, rgba($accent-blue-rgb, 0.08) 100%)
  color rgba(255, 255, 255, 0.98)
  cursor pointer
  display flex
  align-items center
  justify-content center
  transition all 0.3s $ease-out
  outline none
  position relative
  overflow hidden
  box-shadow 0 4px 16px rgba(0, 0, 0, 0.2), 0 0 0 1px rgba(255, 255, 255, 0.05) inset

  &::before
    content ''
    position absolute
    top 0
    left 0
    right 0
    bottom 0
    background linear-gradient(145deg, rgba(255, 255, 255, 0.2) 0%, transparent 50%)
    opacity 0
    transition opacity 0.3s ease

  &:hover
    background linear-gradient(145deg, rgba($accent-blue-rgb, 0.35) 0%, rgba($accent-blue-rgb, 0.18) 100%)
    border-color rgba($accent-blue-rgb, 0.65)
    box-shadow 0 6px 24px rgba($accent-blue-rgb, 0.4), 0 0 0 1px rgba($accent-blue-rgb, 0.25) inset
    transform translateY(-2px) scale(1.02)

  &:hover::before
    opacity 1

  &:active
    transform translateY(0) scale(0.96)
    box-shadow 0 2px 12px rgba($accent-blue-rgb, 0.3)

  &:disabled, &.disabled
    opacity 0.35
    cursor not-allowed
    pointer-events none

  svg
    position relative
    z-index 1
    filter drop-shadow(0 1px 2px rgba(0, 0, 0, 0.25))

// ========== Tab 切换区（稍压缩 + 多色）==========
.video-ai-tab-bar
  flex-shrink 0
  height 72px
  display flex
  align-items center
  justify-content center
  gap 10px
  padding 0 24px
  background rgba(0, 0, 0, 0.18)
  border-bottom 1px solid $border-subtle
  position relative
  z-index 1
  box-shadow 0 2px 12px rgba(0, 0, 0, 0.08)

.video-ai-tab
  padding 10px 26px
  font-size 13px
  font-weight 600
  color $text-secondary
  background rgba(255, 255, 255, 0.04)
  border 1px solid rgba(255, 255, 255, 0.08)
  border-radius 999px
  cursor pointer
  transition all 0.3s $ease-out
  outline none
  position relative
  overflow hidden
  letter-spacing 0.35px
  box-shadow 0 1px 4px rgba(0, 0, 0, 0.1)

  &::before
    content ''
    position absolute
    top 0
    left 0
    right 0
    bottom 0
    background linear-gradient(135deg, rgba($accent-blue-rgb, 0.12) 0%, transparent 100%)
    opacity 0
    transition opacity 0.3s ease

  &:hover
    color rgba(255, 255, 255, 0.95)
    background rgba(255, 255, 255, 0.08)
    border-color rgba($accent-cyan-rgb, 0.4)
    box-shadow 0 4px 16px rgba($accent-cyan-rgb, 0.2)
    transform translateY(-1px)

  &:hover::before
    opacity 1

  &.active
    color #fff
    background linear-gradient(135deg, rgba($accent-blue-rgb, 0.5) 0%, rgba($accent-violet-rgb, 0.35) 100%)
    border-color rgba($accent-violet-rgb, 0.5)
    box-shadow 0 4px 20px rgba($accent-blue-rgb, 0.3), 0 2px 12px rgba($accent-violet-rgb, 0.2), 0 0 0 1px rgba(255, 255, 255, 0.1) inset

    &::before
      opacity 1
      background linear-gradient(135deg, rgba(255, 255, 255, 0.15) 0%, transparent 100%)

  &:active
    transform translateY(0) scale(0.98)

// ========== 内容区 ==========
.video-ai-content
  flex 1
  min-height 0
  overflow-y auto
  overflow-x hidden
  background linear-gradient(180deg, rgba(0, 0, 0, 0.12) 0%, rgba(0, 0, 0, 0.06) 100%)
  transform translateZ(0)
  -webkit-overflow-scrolling touch
  position relative
  z-index 1

  &::-webkit-scrollbar
    width 8px

  &::-webkit-scrollbar-track
    background rgba(0, 0, 0, 0.1)
    border-radius 4px

  &::-webkit-scrollbar-thumb
    background rgba(255, 255, 255, 0.18)
    border-radius 4px

    &:hover
      background rgba(255, 255, 255, 0.28)

.video-ai-content-inner
  padding 24px 28px
  min-height 100%

.video-ai-empty
  color $text-secondary
  text-align center
  padding 56px 24px
  font-size 15px
  font-weight 500

// ========== 转写列表：卡片 + 左侧色条 ==========

.video-ai-transcript-toolbar
  display flex
  justify-content flex-end
  margin-bottom 12px


.transcript-segment
  padding 16px 20px 16px 22px
  border-radius $radius-md
  margin-bottom 12px
  background rgba(255, 255, 255, 0.05)
  border 1px solid rgba(255, 255, 255, 0.08)
  cursor pointer
  transition all 0.25s $ease-out
  word-wrap break-word
  overflow-wrap break-word
  contain layout style paint
  transform translateZ(0)
  position relative
  overflow hidden
  box-shadow $shadow-card

  // 左侧强调条（蓝/青/紫交替）
  &::before
    content ''
    position absolute
    left 0
    top 12px
    bottom 12px
    width 3px
    border-radius 0 2px 2px 0
    opacity 0.9
    transition opacity 0.25s ease, box-shadow 0.25s ease

  &:nth-child(3n+1)::before
    background linear-gradient(180deg, $accent-blue 0%, $accent-blue-light 100%)

  &:nth-child(3n+2)::before
    background linear-gradient(180deg, $accent-cyan 0%, #80deea 100%)

  &:nth-child(3n+3)::before
    background linear-gradient(180deg, $accent-violet 0%, #e1bee7 100%)

  &:hover
    background rgba(255, 255, 255, 0.08)
    border-color rgba($accent-blue-rgb, 0.2)
    box-shadow 0 4px 20px rgba(0, 0, 0, 0.2), 0 0 0 1px rgba(255, 255, 255, 0.06) inset

  &:hover::before
    opacity 1
    box-shadow 0 0 14px rgba($accent-blue-rgb, 0.35)

  &:nth-child(3n+2):hover::before
    box-shadow 0 0 14px rgba($accent-cyan-rgb, 0.4)

  &:nth-child(3n+3):hover::before
    box-shadow 0 0 14px rgba($accent-violet-rgb, 0.4)

  &:last-child
    margin-bottom 0

.transcript-segment div:not(.segment-time)
  max-height 80px
  overflow-y auto
  font-size 14px
  line-height 1.65
  color rgba(255, 255, 255, 0.92)
  letter-spacing 0.02em

.segment-time
  font-size 11px
  font-weight 700
  color $accent-cyan
  margin-bottom 10px
  font-family 'SF Mono', 'Monaco', 'Consolas', monospace
  letter-spacing 0.08em
  text-transform uppercase
  font-variant-numeric tabular-nums
  text-shadow 0 0 16px rgba($accent-cyan-rgb, 0.35)

// ========== 笔记区 ==========
.video-ai-note-wrap
  max-width 640px

.video-ai-note-toolbar
  display flex
  justify-content flex-end
  margin-bottom 12px

.video-ai-export-btn
  display inline-flex
  align-items center
  gap 6px
  padding 6px 14px
  font-size 12px
  font-weight 600
  color rgba(255, 255, 255, 0.85)
  background rgba(255, 255, 255, 0.06)
  border 1px solid rgba(255, 255, 255, 0.12)
  border-radius 20px
  cursor pointer
  transition all 0.2s ease
  outline none

  &:hover
    background rgba($accent-blue-rgb, 0.2)
    border-color rgba($accent-blue-rgb, 0.4)
    color #fff

  &:active
    transform scale(0.96)

.summary-section
  margin-bottom 0
  padding 4px 0

.note-content
  font-size 14px
  line-height 1.85
  color $text-primary
  word-wrap break-word
  overflow-wrap break-word

  h1
    font-size 1.4rem
    color #fff
    margin 1.4rem 0 0.9rem
    padding-bottom 12px
    border-bottom 2px solid rgba($accent-blue-rgb, 0.5)
    font-weight 700
    letter-spacing 0.02em
    text-shadow 0 1px 2px rgba(0, 0, 0, 0.2)

  h2
    font-size 1.2rem
    color $accent-blue-light
    margin 1.1rem 0 0.7rem
    padding-bottom 8px
    border-bottom 1px solid rgba(255, 255, 255, 0.12)
    font-weight 600

  h3, h4, h5, h6
    font-size 1.05rem
    color rgba(255, 255, 255, 0.95)
    margin 0.9rem 0 0.5rem
    font-weight 600

  p
    margin 0.7rem 0
    color rgba(255, 255, 255, 0.88)

  ul, ol
    margin 0.7rem 0
    padding-left 1.6rem

  li
    margin 0.4rem 0

  strong
    color $accent-blue-light
    font-weight 700

  code
    background rgba(0, 0, 0, 0.25)
    padding 3px 10px
    border-radius 6px
    font-size 0.9em
    color $accent-blue-light
    border 1px solid rgba(255, 255, 255, 0.06)
    box-shadow 0 2px 6px rgba(0, 0, 0, 0.15) inset

  pre
    background rgba(0, 0, 0, 0.2)
    padding 16px 18px
    border-radius $radius-sm
    overflow-x auto
    margin 1rem 0
    border 1px solid rgba(255, 255, 255, 0.08)
    box-shadow 0 2px 12px rgba(0, 0, 0, 0.2) inset

  pre code
    background transparent
    padding 0
    color rgba(255, 255, 255, 0.9)
    border none
    box-shadow none

  blockquote
    border-left 4px solid rgba($accent-blue-rgb, 0.7)
    padding-left 1.2rem
    margin 1.2rem 0
    color $text-secondary
    font-style italic
    background rgba(255, 255, 255, 0.03)
    padding 12px 12px 12px 1.2rem
    border-radius 0 $radius-sm $radius-sm 0

  a
    color $accent-blue-light
    text-decoration none
    font-weight 500

  a:hover
    text-decoration underline
    text-shadow 0 0 20px rgba($accent-blue-rgb, 0.3)

// ========== 脑图占位 ==========
.video-ai-mindmap-wrap
  height 100%

.mindmap-fallback
  padding 24px 28px
  height 100%
  box-sizing border-box
  overflow auto
  background rgba(0, 0, 0, 0.15)
  border 1px solid rgba(255, 255, 255, 0.08)
  border-radius $radius-lg
  box-shadow $shadow-card

.mindmap-markdown-preview
  margin 0
  font-size 13px
  line-height 1.75
  color rgba(255, 255, 255, 0.7)
  white-space pre-wrap
  word-break break-word
  font-family 'SF Mono', Monaco, Consolas, monospace
  letter-spacing 0.04em
