// =========================================================
// Video2Pdf - 任务窗口式深色主题
// 深空蓝渐变 + 扫描网格背景 + 青绿/青蓝强调色 + 玻璃拟态
// 与 src/task-window/index.styl 视觉语言保持一致
// =========================================================

html, body, #video2pdf-container
  width 100%
  height 100%
  min-height 100vh
  margin 0

// ---- 根容器：深色渐变 + 角光晕 + 扫描网格 ----
.vp-root
  position relative
  box-sizing border-box
  width 100%
  max-width 100%
  min-height 100vh
  height 100vh
  padding 18px 14px
  color #e6edf3
  font-family -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif
  background radial-gradient(circle at 82% -10%, rgba(20, 184, 166, 0.18), transparent 36%), radial-gradient(circle at 8% 14%, rgba(88, 166, 255, 0.14), transparent 30%), linear-gradient(145deg, #070b13 0%, #0d1420 45%, #071014 100%)
  overflow-y auto
  overflow-x hidden

.vp-root::before
  content ''
  position absolute
  inset 0
  pointer-events none
  background linear-gradient(rgba(125, 211, 252, 0.035) 1px, transparent 1px), linear-gradient(90deg, rgba(125, 211, 252, 0.035) 1px, transparent 1px)
  background-size 26px 26px
  mask-image linear-gradient(to bottom, rgba(0, 0, 0, 0.9), transparent 82%)
  z-index 0

.vp-root::after
  content ''
  position absolute
  top -16%
  right -14%
  width 380px
  height 380px
  pointer-events none
  background conic-gradient(from 145deg, rgba(88, 166, 255, 0.18), rgba(46, 160, 67, 0.04), rgba(210, 168, 255, 0.14), rgba(88, 166, 255, 0.18))
  filter blur(54px)
  opacity 0.5
  z-index 0

// ---- 页面标题 ----
.vp-title-row
  position relative
  display flex
  align-items center
  text-align center
  z-index 1
  margin-bottom 14px
  padding 16px 18px
  border 1px solid rgba(56, 189, 248, 0.28)
  border-radius 16px
  background linear-gradient(135deg, rgba(2, 6, 23, 0.92), rgba(7, 25, 45, 0.85), rgba(2, 6, 23, 0.92))
  box-shadow 0 0 24px rgba(56, 189, 248, 0.08), 0 0 60px rgba(14, 165, 233, 0.06), 0 16px 40px rgba(0, 0, 0, 0.35), inset 0 1px 0 rgba(125, 211, 252, 0.08)
  overflow hidden

// 底部发光线
.vp-title-row::after
  content ''
  position absolute
  left 16px
  right 16px
  bottom -1px
  height 1px
  background linear-gradient(90deg, transparent, rgba(56, 189, 248, 0.8), rgba(34, 211, 238, 0.6), rgba(56, 189, 248, 0.8), transparent)
  box-shadow 0 0 12px rgba(56, 189, 248, 0.5), 0 0 28px rgba(56, 189, 248, 0.2)

// 扫光动画层
.vp-title-row::before
  content ''
  position absolute
  top 0
  left -120%
  width 60%
  height 100%
  background linear-gradient(105deg, transparent 30%, rgba(56, 189, 248, 0.06) 46%, rgba(125, 211, 252, 0.12) 50%, rgba(56, 189, 248, 0.06) 54%, transparent 70%)
  animation vpTitleSweep 4s ease-in-out infinite
  pointer-events none
  z-index 2

.vp-title-main
  position relative
  z-index 3
  display inline-flex
  align-items center
  gap 10px

.vp-title-line
  position relative
  z-index 3
  display inline-flex
  align-items center
  justify-content center
  gap 0
  margin 0 auto

.vp-title-local-link
  position absolute
  top 12px
  right 14px
  z-index 4
  padding 0
  border none
  background transparent
  color #67e8f9
  font-size 13px
  font-weight 650
  letter-spacing 0.8px
  line-height 1
  text-shadow 0 0 10px rgba(56, 189, 248, 0.5)
  cursor pointer

.vp-title-local-link:hover
  color #bae6fd
  text-shadow 0 0 14px rgba(56, 189, 248, 0.72), 0 0 28px rgba(56, 189, 248, 0.3)

.vp-title-badge
  position relative
  flex-shrink 0
  width 34px
  height 34px
  border 1px solid rgba(56, 189, 248, 0.58)
  border-radius 10px
  background radial-gradient(circle at 30% 30%, rgba(125, 211, 252, 0.32), rgba(14, 165, 233, 0.12) 45%, rgba(2, 6, 23, 0.72) 100%)
  box-shadow 0 0 14px rgba(56, 189, 248, 0.35), 0 0 30px rgba(56, 189, 248, 0.2), inset 0 0 16px rgba(56, 189, 248, 0.18)
  z-index 3

.vp-title-badge::before
  content ''
  position absolute
  inset 8px
  border 1px solid rgba(125, 211, 252, 0.72)
  border-radius 6px
  box-shadow 0 0 10px rgba(56, 189, 248, 0.36)

.vp-title-badge::after
  content ''
  position absolute
  left 50%
  top 50%
  width 12px
  height 12px
  transform translate(-50%, -50%) rotate(45deg)
  border 1px solid rgba(191, 219, 254, 0.86)
  border-radius 2px
  box-shadow 0 0 12px rgba(125, 211, 252, 0.58)

.vp-page-title
  margin 0
  font-size 26px
  font-weight 800
  letter-spacing 1px
  line-height 1.2
  background linear-gradient(135deg, #e0f2fe 0%, #7dd3fc 40%, #38bdf8 60%, #22d3ee 100%)
  -webkit-background-clip text
  -webkit-text-fill-color transparent
  background-clip text
  filter drop-shadow(0 0 18px rgba(56, 189, 248, 0.35))

.vp-page-subtitle
  position absolute
  left 100%
  bottom 2px
  z-index 3
  margin 0 0 0 12px
  color rgba(148, 204, 236, 0.85)
  font-size 13px
  line-height 1
  letter-spacing 0.3px
  text-align left
  white-space nowrap
  text-shadow 0 0 10px rgba(56, 189, 248, 0.12)

// ---- 顶部 Toolbar：玻璃黑 + 底部渐变发光线 ----
.vp-toolbar
  position relative
  z-index 1
  display flex
  align-items center
  flex-wrap wrap
  gap 10px
  margin-bottom 18px
  padding 10px 14px
  border 1px solid rgba(125, 211, 252, 0.18)
  border-radius 14px
  background linear-gradient(120deg, rgba(8, 13, 23, 0.88), rgba(8, 25, 27, 0.78))
  backdrop-filter blur(18px)
  box-shadow 0 18px 44px rgba(0, 0, 0, 0.32), inset 0 1px 0 rgba(255, 255, 255, 0.04)

.vp-toolbar::after
  content ''
  position absolute
  left 14px
  right 14px
  bottom -1px
  height 1px
  background linear-gradient(90deg, transparent, rgba(125, 211, 252, 0.72), rgba(110, 231, 183, 0.46), transparent)

.vp-group
  display inline-flex
  align-items center
  gap 8px

.vp-group-icon
  color #7dd3fc
  font-size 14px
  filter drop-shadow(0 0 6px rgba(125, 211, 252, 0.32))

.vp-label
  color #cbd5e1
  font-size 13px
  font-weight 650
  letter-spacing 0.3px

.vp-unit
  color #8ea7bb
  font-size 13px

.vp-range-dash
  color #6b7c93
  font-weight 600

.vp-divider
  width 1px
  height 22px
  background linear-gradient(180deg, transparent, rgba(125, 211, 252, 0.28), transparent)

// ---- 输入框：深底 + 青蓝边框 + 聚焦光晕 ----
.vp-time-input.ant-input
  width 94px

.vp-num-input.ant-input
  width 80px

.vp-toolbar .ant-input
  height 30px
  padding 4px 10px
  border-radius 10px
  border 1px solid rgba(125, 211, 252, 0.22)
  background linear-gradient(180deg, rgba(15, 23, 42, 0.78), rgba(8, 13, 23, 0.72))
  color #e6edf3
  font-size 13px
  letter-spacing 0.2px
  font-variant-numeric tabular-nums
  box-shadow inset 0 1px 0 rgba(255, 255, 255, 0.04), 0 6px 18px rgba(0, 0, 0, 0.22)
  transition border-color .18s ease, box-shadow .18s ease, background .18s ease

.vp-toolbar .ant-input::placeholder
  color #6b7c93

.vp-toolbar .ant-input:hover
  border-color rgba(125, 211, 252, 0.42)
  background linear-gradient(180deg, rgba(15, 23, 42, 0.88), rgba(8, 13, 23, 0.78))

.vp-toolbar .ant-input:focus
  border-color rgba(125, 211, 252, 0.62)
  background linear-gradient(180deg, rgba(15, 23, 42, 0.92), rgba(8, 13, 23, 0.85))
  box-shadow inset 0 1px 0 rgba(255, 255, 255, 0.06), 0 0 0 3px rgba(56, 189, 248, 0.18), 0 8px 22px rgba(14, 165, 233, 0.16)

// 错误态
.vp-toolbar .ant-input-status-error
  border-color rgba(252, 165, 165, 0.55) !important
  box-shadow 0 0 0 3px rgba(239, 68, 68, 0.18), inset 0 1px 0 rgba(255, 255, 255, 0.04) !important

// ---- Segmented 去重选择器 ----
.vp-toolbar .ant-segmented
  padding 2px
  border 1px solid rgba(125, 211, 252, 0.22)
  background linear-gradient(180deg, rgba(15, 23, 42, 0.78), rgba(8, 13, 23, 0.72))
  border-radius 10px

.vp-toolbar .ant-segmented-item
  min-width 36px
  border-radius 7px
  color #9fb7c9
  font-size 12px
  font-weight 650
  transition all .18s ease

.vp-toolbar .ant-segmented-item:hover
  color #e6edf3

.vp-toolbar .ant-segmented .ant-segmented-item-selected
  color #f8fafc !important
  background linear-gradient(135deg, #14b8a6, #2563eb) !important
  box-shadow 0 6px 16px rgba(20, 184, 166, 0.32), inset 0 1px 0 rgba(255, 255, 255, 0.14) !important

.vp-toolbar .ant-segmented .ant-segmented-thumb
  background linear-gradient(135deg, #14b8a6, #2563eb) !important
  box-shadow 0 6px 16px rgba(20, 184, 166, 0.32), inset 0 1px 0 rgba(255, 255, 255, 0.14) !important
  border-radius 7px

.vp-help
  color #7dd3fc
  font-size 14px
  cursor pointer
  filter drop-shadow(0 0 6px rgba(125, 211, 252, 0.28))

// ---- 操作按钮组：拼成 pill ----
.vp-actions
  display inline-flex
  align-items center
  gap 4px
  padding 3px
  border 1px solid rgba(125, 211, 252, 0.18)
  border-radius 12px
  background linear-gradient(180deg, rgba(15, 23, 42, 0.78), rgba(8, 13, 23, 0.7))
  box-shadow inset 0 1px 0 rgba(255, 255, 255, 0.04)

.vp-btn
  width 34px
  height 30px
  border none
  outline none
  display inline-flex
  align-items center
  justify-content center
  border-radius 9px
  background transparent
  color #9fb7c9
  cursor pointer
  transition background .18s ease, color .18s ease, transform .18s ease, box-shadow .18s ease

.vp-btn:hover
  color #e6edf3
  background linear-gradient(180deg, rgba(14, 165, 233, 0.22), rgba(15, 23, 42, 0.55))
  box-shadow 0 6px 16px rgba(14, 165, 233, 0.18), inset 0 1px 0 rgba(255, 255, 255, 0.06)
  transform translateY(-1px)

.vp-btn svg
  width 17px
  height 17px

// 主按钮：纯图标风格
.vp-btn.vp-btn-primary
  color #86efac
  border none !important
  background transparent !important
  box-shadow none !important

.vp-btn.vp-btn-primary:hover
  color #bbf7d0
  border none !important
  background transparent !important
  box-shadow 0 0 12px rgba(16, 185, 129, 0.28) !important
  transform none

// 危险按钮：暗红
.vp-btn-danger:hover
  color #fecaca
  background linear-gradient(180deg, rgba(127, 29, 29, 0.42), rgba(15, 23, 42, 0.72))
  box-shadow 0 8px 20px rgba(239, 68, 68, 0.18), inset 0 1px 0 rgba(255, 255, 255, 0.06)

.vp-btn.vp-btn-stop
  color #fca5a5
  border none !important
  background transparent !important
  box-shadow none !important

.vp-btn.vp-btn-stop:hover
  color #fee2e2
  border none !important
  background transparent !important
  box-shadow 0 0 12px rgba(239, 68, 68, 0.3) !important
  transform none

.vp-btn.is-idle
  opacity 0.42
  cursor pointer

.vp-btn.is-idle:hover
  opacity 0.6
  background transparent !important
  border none !important
  box-shadow none !important
  transform none

// 录制中：青蓝呼吸 + 边框流光
.vp-btn.is-active
  color #fde68a
  background radial-gradient(circle at 45% 35%, rgba(250, 204, 21, 0.34), rgba(8, 16, 28, 0.76))
  box-shadow 0 0 12px rgba(250, 204, 21, 0.42), 0 0 28px rgba(234, 179, 8, 0.22), inset 0 1px 0 rgba(255, 255, 255, 0.12)
  animation vpLampPulse 1.8s ease-in-out infinite

// ---- 全选 Checkbox ----
.vp-select-all
  color #cbd5e1
  font-size 13px
  font-weight 650

.vp-select-all .ant-checkbox-inner
  width 16px
  height 16px
  border-radius 5px
  border 1px solid rgba(125, 211, 252, 0.42)
  background linear-gradient(180deg, rgba(15, 23, 42, 0.85), rgba(8, 13, 23, 0.78))

.vp-select-all .ant-checkbox-checked .ant-checkbox-inner
  background linear-gradient(135deg, #14b8a6, #2563eb) !important
  border-color rgba(125, 211, 252, 0.62) !important

.vp-select-all:hover .ant-checkbox-inner
  border-color rgba(125, 211, 252, 0.62)

// ---- 截图流容器 ----
.vp-grid-wrap
  position relative
  z-index 1
  border 1px solid rgba(125, 211, 252, 0.12)
  border-radius 16px
  background linear-gradient(180deg, rgba(6, 16, 30, 0.55), rgba(8, 13, 23, 0.4))
  padding 16px
  min-height 420px
  box-shadow inset 0 1px 0 rgba(255, 255, 255, 0.04), 0 18px 42px rgba(0, 0, 0, 0.28)

.vp-grid-wrap.is-filming::after
  content ''
  position absolute
  inset -1px
  border-radius 16px
  border 1px solid transparent
  background linear-gradient(135deg, rgba(125, 211, 252, 0.8), rgba(52, 211, 153, 0.6)) border-box
  -webkit-mask linear-gradient(#000 0 0) padding-box, linear-gradient(#000 0 0)
  -webkit-mask-composite xor
  mask-composite exclude
  pointer-events none
  animation vpGlow 1.6s ease-in-out infinite

// ---- 网格 ----
.vp-grid
  display grid
  grid-template-columns repeat(4, minmax(0, 1fr))
  gap 14px

// ---- 卡片：深底 + 青蓝细边 + hover 升起 ----
.vp-card
  position relative
  border 1px solid rgba(125, 211, 252, 0.14)
  border-radius 12px
  background linear-gradient(135deg, rgba(15, 23, 42, 0.92), rgba(8, 13, 23, 0.82))
  box-shadow 0 12px 28px rgba(0, 0, 0, 0.28), inset 0 1px 0 rgba(255, 255, 255, 0.04)
  overflow hidden
  transition border-color .18s ease, transform .18s ease, box-shadow .18s ease

.vp-card::before
  content ''
  position absolute
  inset 0
  pointer-events none
  background linear-gradient(120deg, rgba(125, 211, 252, 0.1), transparent 32%, rgba(52, 211, 153, 0.06) 70%, transparent)
  opacity 0
  transition opacity .2s ease
  z-index 1

.vp-card:hover
  transform translateY(-3px)
  border-color rgba(125, 211, 252, 0.42)
  box-shadow 0 18px 38px rgba(0, 0, 0, 0.42), 0 0 30px rgba(14, 165, 233, 0.14)

.vp-card:hover::before
  opacity 1

// 选中态：青绿描边光晕
.vp-card.is-checked
  border-color rgba(52, 211, 153, 0.7)
  box-shadow 0 0 0 1px rgba(52, 211, 153, 0.32) inset, 0 18px 38px rgba(0, 0, 0, 0.42), 0 0 32px rgba(16, 185, 129, 0.18)

// ---- 缩略图 ----
.vp-thumb
  position relative
  background #0b1220

.vp-thumb .ant-image
  width 100%
  display block

.vp-thumb .ant-image-img
  width 100%
  min-height 100px
  object-fit cover
  display block

.vp-thumb .ant-image-mask
  border-radius 0
  background rgba(2, 6, 14, 0.55)
  color #e6edf3

// 左上：复选框徽章
.vp-card-check
  position absolute
  top 8px
  left 8px
  z-index 3
  padding 3px
  border-radius 7px
  background rgba(8, 13, 23, 0.78)
  border 1px solid rgba(125, 211, 252, 0.22)
  backdrop-filter blur(6px)

.vp-card-check .ant-checkbox-inner
  width 16px
  height 16px
  border-radius 4px
  border 1px solid rgba(125, 211, 252, 0.42)
  background linear-gradient(180deg, rgba(15, 23, 42, 0.85), rgba(8, 13, 23, 0.78))

.vp-card-check .ant-checkbox-checked .ant-checkbox-inner
  background linear-gradient(135deg, #14b8a6, #2563eb) !important
  border-color rgba(125, 211, 252, 0.6) !important

// 左下：时间徽章（mono）
.vp-card-time
  position absolute
  left 8px
  bottom 8px
  z-index 2
  padding 2px 8px
  border-radius 999px
  color #bae6fd
  font-size 11px
  font-weight 700
  letter-spacing .3px
  font-family 'SF Mono', 'JetBrains Mono', 'Roboto Mono', monospace
  font-variant-numeric tabular-nums
  background rgba(14, 165, 233, 0.16)
  border 1px solid rgba(125, 211, 252, 0.28)
  backdrop-filter blur(6px)
  box-shadow 0 4px 10px rgba(0, 0, 0, 0.32)

// ---- 裁剪 Modal：深色适配 ----
.vp-crop-modal .ant-modal-content
  border 1px solid rgba(125, 211, 252, 0.22)
  border-radius 16px
  background linear-gradient(145deg, #0d1420, #070b13)
  color #e6edf3
  box-shadow 0 24px 64px rgba(0, 0, 0, 0.55)

.vp-crop-modal .ant-modal-header
  border-bottom 1px solid rgba(125, 211, 252, 0.18)
  background transparent
  border-radius 16px 16px 0 0

.vp-crop-modal .ant-modal-title
  color #e6edf3
  font-weight 700
  letter-spacing 0.4px

.vp-crop-modal .ant-modal-close-x
  color #9fb7c9

.vp-crop-modal .ant-modal-footer
  border-top 1px solid rgba(125, 211, 252, 0.14)

.vp-crop-modal .ant-btn
  border-radius 10px

.vp-crop-modal .ant-btn-default
  color #dbeafe
  border-color rgba(125, 211, 252, 0.28)
  background linear-gradient(180deg, rgba(30, 41, 59, 0.78), rgba(15, 23, 42, 0.72))

.vp-crop-modal .ant-btn-default:hover
  color #f8fafc
  border-color rgba(125, 211, 252, 0.5)
  background linear-gradient(180deg, rgba(14, 165, 233, 0.28), rgba(15, 23, 42, 0.82))

.vp-crop-modal .ant-btn-primary
  border none
  background linear-gradient(135deg, #14b8a6, #238636)
  box-shadow 0 10px 22px rgba(20, 184, 166, 0.28), inset 0 1px 0 rgba(255, 255, 255, 0.15)

.vp-crop-modal .ant-btn-primary:hover
  background linear-gradient(135deg, #2dd4bf, #2ea043) !important
  box-shadow 0 12px 26px rgba(20, 184, 166, 0.42), inset 0 1px 0 rgba(255, 255, 255, 0.18)

// ---- 滚动条 ----
.vp-root::-webkit-scrollbar
  width 10px
  height 10px

.vp-root::-webkit-scrollbar-track
  background rgba(8, 13, 23, 0.4)

.vp-root::-webkit-scrollbar-thumb
  border-radius 999px
  background linear-gradient(180deg, rgba(125, 211, 252, 0.35), rgba(52, 211, 153, 0.28))
  border 2px solid transparent
  background-clip padding-box

.vp-root::-webkit-scrollbar-thumb:hover
  background linear-gradient(180deg, rgba(125, 211, 252, 0.55), rgba(52, 211, 153, 0.48))
  background-clip padding-box

// ---- 动画 ----
@keyframes vpTitleSweep
  0%
    left -120%
  100%
    left 160%

@keyframes vpGlow
  0%, 100%
    opacity .55
  50%
    opacity 1

@keyframes vpLampPulse
  0%
    box-shadow 0 0 8px rgba(250, 204, 21, 0.28), 0 0 20px rgba(234, 179, 8, 0.14), inset 0 1px 0 rgba(255, 255, 255, 0.12)
  50%
    box-shadow 0 0 14px rgba(250, 204, 21, 0.56), 0 0 34px rgba(234, 179, 8, 0.32), inset 0 1px 0 rgba(255, 255, 255, 0.16)
  100%
    box-shadow 0 0 8px rgba(250, 204, 21, 0.28), 0 0 20px rgba(234, 179, 8, 0.14), inset 0 1px 0 rgba(255, 255, 255, 0.12)

// ---- 响应式 ----
@media (max-width: 992px)
  .vp-toolbar
    gap 8px
    padding 10px

  .vp-divider
    display none

@media (max-width: 768px)
  .vp-root
    padding 14px 8px

  .vp-title-row
    padding 12px 14px

  .vp-title-local-link
    top 10px
    right 12px
    font-size 12px

  .vp-title-badge
    width 30px
    height 30px

  .vp-page-title
    font-size 20px

  .vp-page-subtitle
    font-size 12px
    bottom 1px

  .vp-time-input.ant-input
    width 86px

  .vp-grid
    grid-template-columns repeat(4, minmax(0, 1fr))
    gap 12px
